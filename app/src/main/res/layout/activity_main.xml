<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- ── Slider view ─────────────────────────────────────────────── -->
    <com.theadityatiwari.revealslider.RevealSliderView
        android:id="@+id/revealSlider"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        app:blurType="gaussian"
        app:blurRadius="15"
        app:cornerRadius="0dp"
        app:initialPosition="0.5"
        app:showLabels="true" />

    <!-- Position readout -->
    <TextView
        android:id="@+id/tvPosition"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingVertical="6dp"
        android:text="@string/position_default"
        android:textAppearance="?attr/textAppearanceBodyMedium" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOutlineVariant" />

    <!-- ── Controls ────────────────────────────────────────────────── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Blur Type ─────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_blur_type"
                android:textAppearance="?attr/textAppearanceLabelLarge" />

            <Spinner
                android:id="@+id/spinnerBlurType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp" />

            <!-- Blur Radius group (hidden when PIXELATE is selected) -->
            <LinearLayout
                android:id="@+id/groupBlurRadius"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_blur_radius"
                        android:textAppearance="?attr/textAppearanceLabelLarge" />

                    <TextView
                        android:id="@+id/tvBlurRadiusValue"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="15"
                        android:textAppearance="?attr/textAppearanceBodyMedium" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekBlurRadius"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:max="24"
                    android:progress="14" />
            </LinearLayout>

            <!-- Pixel Size group (shown only when PIXELATE is selected) -->
            <LinearLayout
                android:id="@+id/groupPixelSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_pixel_size"
                        android:textAppearance="?attr/textAppearanceLabelLarge" />

                    <TextView
                        android:id="@+id/tvPixelSizeValue"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="16"
                        android:textAppearance="?attr/textAppearanceBodyMedium" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekPixelSize"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:max="46"
                    android:progress="14" />
            </LinearLayout>

            <!-- Direction ─────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_direction"
                android:textAppearance="?attr/textAppearanceLabelLarge" />

            <RadioGroup
                android:id="@+id/rgDirection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbBeforeAfter"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:checked="true"
                    android:text="@string/direction_before_after" />

                <RadioButton
                    android:id="@+id/rbAfterBefore"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/direction_after_before" />
            </RadioGroup>

            <!-- Labels ────────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_show_labels"
                    android:textAppearance="?attr/textAppearanceLabelLarge" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchLabels"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <!-- Corner Radius ──────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_corner_radius"
                    android:textAppearance="?attr/textAppearanceLabelLarge" />

                <TextView
                    android:id="@+id/tvCornerRadiusValue"
                    android:layout_width="52dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:text="0dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seekCornerRadius"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:max="64"
                android:progress="0" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
